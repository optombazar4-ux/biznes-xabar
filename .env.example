# === Docker Compose uchun asosiy sozlamalar ===
# Nusxalash: cp .env.example .env

# AI provayder: gemini (standart) yoki claude
AI_PROVIDER=gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3.1-flash-lite
# ANTHROPIC_API_KEY=sk-ant-...

# Admin panel tokeni (kuchli tasodifiy qiymat qo'ying!)
ADMIN_TOKEN=maxfiy-admin-token

# Telegram (bot va kanal uchun)
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHANNEL_ID=@biznesxabari

# PostgreSQL paroli
POSTGRES_PASSWORD=kuchli-parol

# Avto-chop etish sozlamalari
AUTO_PUBLISH=true
AUTO_TELEGRAM=true
AUTO_TELEGRAM_MIN_IMPORTANCE=4

# Pipeline necha soniyada bir ishlaydi (3600 = har soatda)
PIPELINE_INTERVAL=3600

# Rasm topilmaganda Gemini bilan generatsiya (pullik — standart o'chiq)
IMAGE_GENERATION=false
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# Generatsiya qilingan rasmlarning ommaviy manzili (prod'da API domeningiz)
BACKEND_PUBLIC_URL=http://localhost:8000

# Tashqi manzillar (serverga qo'yganda domeningizni yozing)
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000
SITE_URL=http://localhost:3000
