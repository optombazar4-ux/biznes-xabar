# Ma'lumotlar bazasi (prod: PostgreSQL, lokal: sqlite standart)
# DATABASE_URL=postgresql+psycopg2://user:parol@localhost:5432/ainews
DATABASE_URL=sqlite:///./ainews.db

# AI provayder: gemini (standart) yoki claude
AI_PROVIDER=gemini

# Gemini API kaliti — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3.1-flash-lite

# Claude (ixtiyoriy, AI_PROVIDER=claude bo'lsa) — https://platform.claude.com
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# Admin panel tokeni (kuchli tasodifiy qiymat qo'ying!)
ADMIN_TOKEN=maxfiy-admin-token

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHANNEL_ID=@biznesxabari

# Avto-chop etish (cron bilan to'liq avtomatik rejim).
# false qilsangiz maqolalar admin tasdig'ini kutadi (pending).
AUTO_PUBLISH=true
AUTO_PUBLISH_MIN_IMPORTANCE=1

# Muhim yangiliklarni (bahosi >= 4) Telegram kanalga avtomatik yuborish
AUTO_TELEGRAM=true
AUTO_TELEGRAM_MIN_IMPORTANCE=4

# Rasm topilmaganda (RSS + og:image ham bo'sh) Gemini bilan generatsiya.
# Pullik xizmat — shuning uchun standart o'chiq.
IMAGE_GENERATION=false
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# Generatsiya qilingan rasmlarning ommaviy manzili (prod'da domeningiz)
BACKEND_PUBLIC_URL=http://localhost:8000

# Frontend manzili (CORS)
FRONTEND_ORIGIN=http://localhost:3000
